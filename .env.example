# 复制为 .env 或 .env.local（本地开发）或 .env.production（构建时）
# 不配置 Firebase 则数据仅保存在本机 localStorage
#
# 方案 A（dewdew 独立部署）：与主站共用同一 Firebase 项目，值从主站或 Firebase 控制台获取，保持一致。

# 部署路径：独立子域 https://dewdew.dewniverse.me 时一般为 /
# 若部署在其它子路径则按实际填写
VITE_BASE_PATH=/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=你的项目.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=你的项目ID
VITE_FIREBASE_STORAGE_BUCKET=你的项目.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 与主站统一登录（方案 A 必须）：设为 true 时未登录会跳主站登录
VITE_FIREBASE_REQUIRE_LOGIN=true
# 门控页「前往主站登录」跳转地址（returnUrl 由代码追加）
VITE_MAIN_SITE_LOGIN_URL=https://www.dewniverse.me/login
